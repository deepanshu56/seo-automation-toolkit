# Copy this file to ".env" and fill in your own keys.
# .env is git-ignored so your secrets never get committed.

# Google PageSpeed Insights API key (pagespeed_audit.py)
# Get one at: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Path to your Google OAuth client secret JSON (index_inspector.py)
# Search Console API must be enabled in your Google Cloud project.
GSC_CLIENT_SECRET=client_secret.json
